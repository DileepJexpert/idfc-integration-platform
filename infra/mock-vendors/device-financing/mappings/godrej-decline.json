{
  "priority": 2,
  "request": {
    "method": "POST",
    "urlPathPattern": "/vendor/device-financing/(validate|block)",
    "bodyPatterns": [ { "matchesJsonPath": "$[?(@.brand == 'GODREJ')]" }, { "matchesJsonPath": "$[?(@.deviceId == 'DEV-DECLINE')]" } ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": { "status": "DECLINED" }
  }
}
