{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPathPattern": "/vendor/device-financing/(validate|block)",
    "bodyPatterns": [ { "matchesJsonPath": "$[?(@.deviceId == 'DEV-FAIL')]" } ]
  },
  "response": {
    "status": 422,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": { "error": "device_rejected" }
  }
}
