{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/api/v1/impsFT",
    "bodyPatterns": [ { "matchesJsonPath": "$[?(@.custBankAccNo == 'BAD-ACCOUNT')]" } ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "transformers": ["response-template"],
    "jsonBody": {
      "reqId": "{{jsonPath request.body '$.reqId'}}",
      "status": "F",
      "transactionId": "",
      "custBankAccNo": "BAD-ACCOUNT",
      "customerName": "",
      "errCode": "E01",
      "errMessage": "invalid beneficiary account"
    }
  }
}
