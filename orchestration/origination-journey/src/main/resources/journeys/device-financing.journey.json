{
  "journeyKey": "device-financing",
  "version": 1,
  "schemaVersion": 2,
  "context": {
    "schemaRef": "device-financing-context@1"
  },
  "startNodeId": "n_brand",
  "nodes": [
    {
      "id": "n_brand",
      "type": "task",
      "capability": "device-financing",
      "operation": "resolveBrand",
      "input": "{ brand: context.brand, type: context.type }",
      "output": "context.brandConfig",
      "next": ["n_route"]
    },
    {
      "id": "n_route",
      "type": "branch",
      "arms": [
        { "when": "context.brandConfig.validationRequired == true", "next": "n_validate" }
      ],
      "default": "n_block"
    },
    {
      "id": "n_validate",
      "type": "task",
      "capability": "device-financing",
      "operation": "validate",
      "input": "{ brand: context.brand, type: context.type, deviceId: context.deviceId, imei: context.imei }",
      "output": "context.validation",
      "next": ["n_vroute"]
    },
    {
      "id": "n_vroute",
      "type": "branch",
      "arms": [
        { "when": "context.validation.approved == true", "next": "n_block" }
      ],
      "default": "n_reject"
    },
    {
      "id": "n_block",
      "type": "task",
      "capability": "device-financing",
      "operation": "block",
      "input": "{ brand: context.brand, type: context.type, deviceId: context.deviceId, imei: context.imei }",
      "output": "context.block",
      "next": ["n_decide"]
    },
    {
      "id": "n_decide",
      "type": "branch",
      "arms": [
        { "when": "context.block.approved == true", "next": "n_approve" }
      ],
      "default": "n_reject"
    },
    {
      "id": "n_approve",
      "type": "terminal",
      "action": "push_decision_to_channel",
      "emit": ["DeviceFinancingApproved"],
      "status": "completed"
    },
    {
      "id": "n_reject",
      "type": "terminal",
      "action": "push_decision_to_channel",
      "emit": ["DeviceFinancingDeclined"],
      "status": "rejected"
    }
  ],
  "layout": {
    "n_brand": { "x": 80.0, "y": 200.0 },
    "n_route": { "x": 280.0, "y": 200.0 },
    "n_validate": { "x": 480.0, "y": 100.0 },
    "n_vroute": { "x": 680.0, "y": 100.0 },
    "n_block": { "x": 680.0, "y": 260.0 },
    "n_decide": { "x": 880.0, "y": 260.0 },
    "n_approve": { "x": 1080.0, "y": 180.0 },
    "n_reject": { "x": 1080.0, "y": 340.0 }
  }
}
