                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{edgeBase}}/api/v1/sfdcUserManagement",
              "host": [
                "{{edgeBase}}"
              ],
              "path": [
                "api",
                "v1",
                "sfdcUserManagement"
              ]
            },
            "description": "Role assignment write svcName. 200 success:true."
          }
        }
      ]
    },
    {
      "name": "3. Fail closed",
      "item": [
        {
          "name": "Write without idempotencyKey -> 422",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"fail closed: HTTP 422 MISSING_IDEMPOTENCY_KEY\", function () {",
                  "    pm.response.to.have.status(422);",
                  "    pm.expect(pm.response.json().code).to.eql(\"MISSING_IDEMPOTENCY_KEY\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{syncToken}}"
              },
              {
                "key": "correlationId",
                "value": "sfdc-{{$guid}}"
              },
              {
                "key": "source",
                "value": "JMI"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"svcName\": \"SFDC_USER_CREATE\",\n  \"orgName\": \"ORG_A\",\n  \"payload\": {\n    \"Username\": \"no.key@orga.example.com\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{edgeBase}}/api/v1/sfdcUserManagement",
              "host": [
                "{{edgeBase}}"
              ],
              "path": [
                "api",
                "v1",
                "sfdcUserManagement"
              ]
            },
            "description": "A write with no idempotencyKey is refused BEFORE SFDC is touched (identity is never mutated without its dedup guarantee)."
          }
        },
        {
          "name": "Unknown org -> 422",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"fail closed: HTTP 422 UNKNOWN_ORG\", function () {",
                  "    pm.response.to.have.status(422);",
                  "    pm.expect(pm.response.json().code).to.eql(\"UNKNOWN_ORG\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
