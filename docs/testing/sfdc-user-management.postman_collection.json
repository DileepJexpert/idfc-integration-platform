              "mode": "raw",
              "raw": "{\n  \"svcName\": \"SFDC_ROLE_ASSIGN\",\n  \"orgName\": \"ORG_A\",\n  \"idempotencyKey\": \"idem-{{$guid}}\",\n  \"payload\": {\n    \"userId\": \"005A0000001aAAAIA2\",\n    \"roleId\": \"00EXX0000000001\"\n  }\n}",
              "options": {
